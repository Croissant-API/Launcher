{
  "name": "croissant-launcher",
  "version": "1.0.0",
  "description": "template",
  "main": "app/app.js",
  "scripts": {
    "start": "set PORT=4536 && react-scripts start",
    "build": "set PORT=4536 && react-scripts build",
    "start-test": "set PORT=4536 && react-scripts test --env=jsdom",
    "eject": "react-scripts eject"
  },
  "build": {
    "appId": "fr.croissant-api.launcher",
    "productName": "Croissant Launcher",
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "discord-rpc": "^4.0.1",
    "node-fetch": "^2.7.0",
    "open": "^10.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "react-scripts": "^5.0.1",
    "simple-git": "^3.27.0",
    "ws": "^8.18.2"
  },
  "author": "fox3000foxy",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
